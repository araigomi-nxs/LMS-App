<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f8f8f8"
    tools:context=".AdminAddBookActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:orientation="horizontal"
        >

        <Button
            android:id="@+id/Back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#FFFFFF"
            android:textColor="#2563eb"
            android:text="Back"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="90dp"
            android:textSize="18sp"
            android:layout_gravity="center"
            android:textColor="#1A1A1A"
            android:fontFamily="sans-serif-medium"
            android:text="Add Book"/>

    </LinearLayout>

    <View
        android:layout_width="wrap_content"
        android:layout_height="30dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="15dp"
        >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15dp"
            android:textColor="#1a1a1a"
            android:fontFamily="sans-serif-medium"
            android:text="Book title:"/>
        <View
            android:layout_width="wrap_content"
            android:layout_height="10dp"/>

        <EditText
            android:id="@+id/etBookTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:padding="12dp"
            android:background="@drawable/flatedittext"
            android:hint="e.g Florante at Laura"/>

        <View
            android:layout_width="wrap_content"
            android:layout_height="15dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15dp"
            android:textColor="#1a1a1a"
            android:fontFamily="sans-serif-medium"
            android:text="Description:"/>

        <View
            android:layout_width="wrap_content"
            android:layout_height="10dp"/>

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:padding="12dp"
            android:background="@drawable/flatedittext"
            android:hint="e.g iujhafijashfkjasf"/>

        <View
            android:layout_width="wrap_content"
            android:layout_height="15dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15dp"
            android:textColor="#1a1a1a"
            android:fontFamily="sans-serif-medium"
            android:text="Authors:"/>
        <View
            android:layout_width="wrap_content"
            android:layout_height="10dp"/>


        <EditText
            android:id="@+id/etAuthors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:padding="12dp"
            android:background="@drawable/flatedittext"
            android:hint="e.g Jose Rizal"/>

        <View
            android:layout_width="wrap_content"
            android:layout_height="15dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15dp"
            android:textColor="#1a1a1a"
            android:fontFamily="sans-serif-medium"
            android:text="Quantity:"/>

        <View
            android:layout_width="wrap_content"
            android:layout_height="10dp"/>

        <EditText
            android:id="@+id/etQuantity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textSize="16sp"
            android:background="@drawable/flatedittext"
            android:hint="e.g 1"/>

        <View
            android:layout_width="wrap_content"
            android:layout_height="15dp"/>

        <Button
            android:id="@+id/btnAddBook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_bg"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:text="ADD BOOK"/>

    </LinearLayout>

</LinearLayout>