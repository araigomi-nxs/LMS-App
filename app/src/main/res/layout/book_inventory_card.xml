<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="4dp"
    android:elevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="10dp"
        android:orientation="horizontal">


        <LinearLayout
            android:layout_width="250dp"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDisplayBookTitle"
                android:layout_width="wrap_content"
                android:textSize="16sp"
                android:textColor="#1A1A1A"
                android:fontFamily="sans-serif-medium"
                android:layout_height="wrap_content"
                android:text="Sample Book Title"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"/>

            <TextView
                android:id="@+id/tvDisplayDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#6b6b6b"
                android:text="Sample Description"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"/>

            <TextView
                android:id="@+id/tvDisplayAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#1A1A1A"
                android:fontFamily="sans-serif"
                android:text="Sample Author"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"/>

            <TextView
                android:id="@+id/tvDisplayQuantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#DC2626"
                android:text="Sample Quantity"/>

        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_marginStart="35dp"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnBorrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:textSize="10sp"
                android:text="borrow"/>

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#FFFFFF"
                android:textSize="10sp"
                android:textColor="#DC2626"
                android:text="delete"/>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>